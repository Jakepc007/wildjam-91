[sub_resource type="GDScript" id="GDScript_dsc64"]
script/source = "extends CharacterBody2D

@onready var target: Marker2D = $\"../Target\"
@onready var target_2: Marker2D = $\"../Target2\"
@onready var navigation_agent_2d: NavigationAgent2D = $NavigationAgent2D
var speed = 200.0

func _physics_process(_delta):
	if navigation_agent_2d.is_navigation_finished():
		return

	# Get the next point in the path
	var current_pos = global_position
	var next_path_pos = navigation_agent_2d.get_next_path_position()
	
	# Calculate velocity
	var new_velocity = (next_path_pos - current_pos).normalized() * speed
	velocity = new_velocity
	move_and_slide()

# Call this to start movement 
func set_movement_target(target_point: Vector2):
	navigation_agent_2d.target_position = target_point


func _on_button_pressed() -> void:
	set_movement_target(target.global_position)
	var temp = target
	target = target_2
	target_2 = temp
	pass # Replace with function body.
"

