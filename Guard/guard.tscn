[sub_resource type="GDScript" id="GDScript_puoqm"]
script/source = "extends Node2D

@onready var visible_on_screen_notifier_2d: VisibleOnScreenNotifier2D = $VisibleOnScreenNotifier2D
@onready var icon: Sprite2D = $Icon

const OFFSCREEN_THRESHOLD : float = 200.0
const ICON_GROW_SPEED : float = 8.0

var _on_screen : bool
var _should_be_displayed : bool
var _initial_icon_scale : Vector2


func _process(delta: float) -> void:
	_place_icon()
	if _should_be_displayed:
		icon.visible = true
		icon.scale = lerp(icon.scale,_initial_icon_scale,delta * ICON_GROW_SPEED)
	else:
		if not _on_screen:
			if icon.scale.x <  0.05:
				icon.visible = false
			else:
				icon.scale = lerp(icon.scale,Vector2.ZERO,delta * ICON_GROW_SPEED)
		else:
			icon.visible = false
			icon.scale = Vector2.ZERO

func _ready() -> void:
	_initial_icon_scale = icon.scale
	icon.top_level = true
	icon.global_position = global_position
	_on_screen = visible_on_screen_notifier_2d.is_on_screen()
	visible_on_screen_notifier_2d.screen_entered.connect(_on_screen_visibility_change.bind(true))
	visible_on_screen_notifier_2d.screen_exited.connect(_on_screen_visibility_change.bind(false))

func _on_screen_visibility_change(on_screen : bool):
	_on_screen = on_screen


func _place_icon():
	if _on_screen:
		_should_be_displayed = false
		return
	if not Global.player:
		_should_be_displayed = false
		return
	var view_rect = get_viewport_rect()
	var viewport_center : Vector2 = Global.player.global_position ## TODO should actually be the camera
	var vec_from_view := (viewport_center - self.global_position)
	var outside_display_threshold : bool = vec_from_view.x - view_rect.size.x/2.0 > OFFSCREEN_THRESHOLD\\
	or vec_from_view.y - view_rect.size.y/2.0 > OFFSCREEN_THRESHOLD
	vec_from_view = vec_from_view.normalized()
	var u = vec_from_view.x
	var v = vec_from_view.y
	var x = 0.5*(sqrt(2+u*u-v*v+2*sqrt(2)*u)-sqrt(2+u*u-v*v-2*sqrt(2)*u))
	var y = 0.5*(sqrt(2-u*u+v*v+2*sqrt(2)*v)-sqrt(2-u*u+v*v-2*sqrt(2)*v))
	x = x * view_rect.size.x/2.0
	y = y * view_rect.size.y/2.0
	icon.global_position = viewport_center - Vector2(x,y) * 0.95
	icon.rotation = atan2(y,x) + PI/2
	_should_be_displayed = not outside_display_threshold
"

