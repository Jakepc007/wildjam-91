[sub_resource type="GDScript" id="GDScript_xdy8g"]
script/source = "extends Area2D
@onready var guard: Guard = $\"..\"
const  ROTATION_SPEED : float = 10

func  _physics_process(delta: float) -> void:
	if guard.velocity.length() < 0.01:
		return
	rotation = lerp_angle(rotation,atan2(guard.velocity.y,guard.velocity.x),delta*ROTATION_SPEED)
"

