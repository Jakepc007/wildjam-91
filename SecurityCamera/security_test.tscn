[sub_resource type="GDScript" id="GDScript_cx7pt"]
script/source = "extends Node2D

@export var guards_container : Node2D


func _ready() -> void:
	for c in get_children():
		if not c is SecurityCamera:
			continue
		c.player_found.connect(_on_security_camera_player_found)

func get_guards() -> Array[Guard]:
	var out : Array[Guard] = []
	for c in guards_container.get_children():
		if not c is Guard:
			continue
		out.append(c)
	return out


func _on_security_camera_player_found(camera: SecurityCamera, location_found: Vector2) -> void:
	for g in get_guards():
		g._investigate_target_location =location_found
		if g._state != Guard.States.CHASE:
			g._state = Guard.States.INVESTIGATE_SPOT
"

