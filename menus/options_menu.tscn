[sub_resource type="GDScript" id="GDScript_wyyb7"]
script/source = "extends Control

var _main_menu_path := preload(\"res://menus/main_menu.tscn\")

func _on_back_pressed() -> void:
	Global.scene_manager.switch_scene(_main_menu_path)

func _process(delta: float) -> void:
	if Input.is_action_just_pressed(\"start\"):
		_on_back_pressed()
"

